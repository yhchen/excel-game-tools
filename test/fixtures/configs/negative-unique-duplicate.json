  "TinyDateFmt": "YYYY/MM/DD",
  "TimeStampUseMS": true,
  "LineBreak": "\n",
  "FractionDigitsFMT": 6,
  "EnableDebugOutput": false,
  "ArraySpliter": [
    ",",
    ";",
    "\n"
  ]
}
