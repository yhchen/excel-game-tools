{
  "IncludeFilesAndPath": [
    "./test/fixtures/negative/UniqueDuplicate.csv"
  ],
  "GroupMap": {
    "*": "(All) Default value",
    "A": "All test",
    "S": "Server",
    "C": "Client"
  },
  "Export": [
    {
      "type": "json",
      "OutputDir": "./test/tmp/negative-unique-duplicate/",
      "GroupFilter": [
        "*"
      ],
      "UseDefaultValueIfEmpty": true
    }
  ],
  "DateFmt": "YYYY/MM/DD HH:mm:ss",
