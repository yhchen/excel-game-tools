{
  "name": "excel-game-tools",
  "version": "3.3.1",
  "description": "excel export with type check using rjs in super fast speed!",
  "bin": "dist/index.js",
  "main": "dist/index.js",
  "scripts": {
    "test": "node scripts/run-tests.js",
    "test:unit": "npm run build && node --test test/unit/*.test.js",
    "test:integration": "npm run build && node --test test/integration/*.test.js",
    "verify:fixtures": "node scripts/verify-fixtures.js",
    "verify:pkg": "node scripts/verify-package-artifacts.js",
    "build": "cd TypeDef && tsc && cd .. && tsc",
    "pkg": "pkg -t node22-linux,node22-macos,node22-win --compress GZip . --out-path=bin/",
    "prepublishOnly": "npm run build"
  },
  "author": "yhchen",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "csv-parse": "^6.1.0",
    "json_to_lua": "^1.1.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "protobufjs": "^8.6.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^18.11.9",
    "@yao-pkg/pkg": "^6.21.0",
    "typescript": "^4.9.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yhchen/excel-game-tools"
  },
  "files": [
    "dist",
    "TypeDef"
  ],
  "keywords": [
    "excel",
    "csv",
    "export",
    "json",
    "lua",
    "protobuf",
    "game",
    "config",
    "typescript"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
